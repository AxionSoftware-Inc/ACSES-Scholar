# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
deploy/env/*.env
!deploy/env/*.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python / django backend
backend/.venv/
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/db.sqlite3
backend/staticfiles/
backend/media/
